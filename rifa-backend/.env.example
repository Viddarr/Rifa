# ══════════════════════════════════════════════
# Copie este arquivo para .env e preencha
# NUNCA suba o .env para o GitHub
# ══════════════════════════════════════════════

NODE_ENV=development
PORT=3001

# PostgreSQL
# Desenvolvimento local: postgresql://postgres:senha@localhost:5432/rifasdb
# Produção (Railway): preencher com a URL gerada pelo Railway
DATABASE_URL=postgresql://postgres:senha@localhost:5432/rifasdb

# JWT — gere uma string aleatória longa
# Sugestão: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=coloque_uma_string_longa_e_aleatoria_aqui
JWT_EXPIRES=8h

# EFI Bank (Gerencianet)
# Obtenha em: https://sejaefi.com.br → API → Credenciais
EFI_CLIENT_ID=seu_client_id
EFI_CLIENT_SECRET=seu_client_secret
EFI_SANDBOX=true
# Sua chave PIX cadastrada na conta EFI Bank
PIX_CHAVE=seu@email.com

# URL do frontend (para o CORS)
FRONTEND_URL=http://localhost:5173
